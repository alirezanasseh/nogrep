{
  "name": "nogrep",
  "version": "1.0.0",
  "description": "Navigable codebase index for Claude Code — stop grepping, start navigating",
  "scope": "project",
  "hooks": {
    "PreToolUse": {
      "matcher": "Bash",
      "command": "hooks/pre-tool-use.sh"
    },
    "SessionStart": {
      "command": "hooks/session-start.sh"
    },
    "UserPromptSubmit": {
      "command": "hooks/prompt-submit.sh"
    }
  }
}
